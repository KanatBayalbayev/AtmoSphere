<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shyn"
    tools:context=".presentation.onboarding.screens.FirstScreen">


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationViewFirstScreen"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/firstscreen" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingExtra="@dimen/cardview_default_radius"
        android:paddingStart="10dp"
        android:paddingTop="22dp"
        android:paddingEnd="10dp"
        android:paddingBottom="22dp"
        android:text="@string/firstscreendesk"
        android:textColor="@color/white"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />


    <TextView
        android:id="@+id/nextButtonFirstScreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textColor="@color/white"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="52dp"
        android:text="@string/next_button"
        android:background="@drawable/orange_button"
        android:layout_marginBottom="50dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:src="@drawable/arrowright"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="14dp"
        app:layout_constraintTop_toTopOf="@+id/nextButtonFirstScreen"
        app:layout_constraintBottom_toBottomOf="@+id/nextButtonFirstScreen"
        app:layout_constraintEnd_toEndOf="@+id/nextButtonFirstScreen" />

